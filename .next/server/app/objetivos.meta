{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/objetivos/layout,_N_T_/objetivos/page,_N_T_/objetivos"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
