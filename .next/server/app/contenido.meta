{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/contenido/layout,_N_T_/contenido/page,_N_T_/contenido"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/contenido/__PAGE__",
    "/contenido",
    "/_index",
    "/_head"
  ]
}